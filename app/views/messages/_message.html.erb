<div class="mb-3 <%= message.role == 'user' ? 'text-end' : 'text-start' %>">
  <div class="d-flex align-items-center gap-2 <%= 'justify-content-end' if message.role == 'user' %> mb-1">
  <% if message.role == 'assistant' %>
    <span class="avatar-ai"><i class="fa-solid fa-bolt"></i></span>
  <% end %>
  <span class="badge <%= message.role == 'user' ? 'bg-primary' : 'bg-secondary' %>">
    <%= message.role.capitalize %>
  </span>
</div>
  <p class="mb-0"><%= message.content %></p>
</div>
