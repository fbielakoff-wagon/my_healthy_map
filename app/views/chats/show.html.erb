<div class="container py-5">
  <div class="app-card">
    <div class="mb-4">
     <%= link_to "← Back to chat history", health_goal_path(@chat.health_goal), class: "text-muted small" %>
    </div
    <h1 class="mb-1"><%= @chat.title.presence || "Chat" %></h1>
    <span class="goal-badge mb-4 d-inline-block"><%= @chat.health_goal.name %></span>

    <div class="mb-4">
    <% if @chat.messages.empty? %>
      <div class="d-flex align-items-center gap-2 mb-4">
        <span class="avatar-ai"><i class="fa-solid fa-bolt"></i></span>
        <div>
          <div class="fw-bold">Healthy Coach</div>
          <div class="text-muted small">AI coaching assistant</div>
        </div>
      </div>
    <% end %>
      <%= render @chat.messages %>
    </div>

    <%= form_with model: @message, url: chat_messages_path(@chat) do |f| %>
      <div class="mb-3">
        <%= f.text_area :content, class: "form-control", rows: 3, placeholder: "Type your message..." %>
      </div>
      <%= f.submit "Send", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>
