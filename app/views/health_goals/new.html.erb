<h1>New Health Goal</h1>

<%= form_with model: @health_goal do |f| %>
  <div>
    <label>Name</label>
    <%= f.text_field :name %>
  </div>

  <div>
    <label>Module</label>
    <%= f.text_field :module %>
  </div>

  <div>
    <label>Content</label>
    <%= f.text_area :content %>
  </div>

  <div>
    <label>System Prompt</label>
    <%= f.text_area :system_prompt %>
  </div>

  <%= f.submit "Create Health Goal" %>
<% end %>
