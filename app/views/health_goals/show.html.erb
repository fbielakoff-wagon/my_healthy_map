<div class="container py-5">
  <div class="mb-4">
    <%= link_to "← Back to new goal", new_health_goal_path, class: "text-muted small" %>
  </div>
  <h1 class="mb-4"><%= @health_goal.name %></h1>

  <%= form_with model: Chat.new, url: health_goal_chats_path(@health_goal) do |f| %>
    <div class="mb-3">
      <%= f.text_field :title, class: "form-control", placeholder: "Optional chat title" %>
    </div>
    <%= f.submit "Start a chat about this goal", class: "btn btn-primary" %>
  <% end %>

  <% if @health_goal.chats.any? %>
    <div class="app-card mt-4">
      <h2 class="mb-3">Your chats</h2>
      <% @health_goal.chats.each do |chat| %>
        <div class="ai-divider py-2">
          <%= link_to "#{chat.title.presence || 'Untitled chat'} (#{chat.created_at.strftime('%b %d')})", chat_path(chat) %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
